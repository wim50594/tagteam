# ─────────────────────────────────────────────────────────────
# TagTeam – Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Database (primary store) ───────────────────────────────────
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://tagteam:tagteam@postgres:5432/tagteam
# SQLite (good for local dev / small deployments):
# DATABASE_URL=sqlite+aiosqlite:////data/tagteam.db

# ── Redis (optional cache layer only) ──────────────────────────
# If left unset, caching is disabled and everything runs straight
# against the database above.
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=300

# ── Auth / JWT ────────────────────────────────────────────────
# REQUIRED. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# Whether the refresh cookie requires HTTPS (Secure flag). Disable for
# local HTTP-only development; always enable in production.
COOKIE_SECURE=true

# ── Bootstrap Admin (optional) ───────────────────────────────
# Set ADMIN_BOOTSTRAP=true and provide both ADMIN_USERNAME and
# ADMIN_PASSWORD to create an admin account on first startup.
# If ADMIN_BOOTSTRAP is false or unset, the first user who registers
# (via invitation) automatically becomes admin.
ADMIN_BOOTSTRAP=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Storage ──────────────────────────────────────────────────
MEDIA_DIR=/data/media
